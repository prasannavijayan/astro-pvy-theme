---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="container py-12">
    <header class="max-w-3xl mx-auto mb-12">
      <a href="/blog" class="inline-flex items-center text-accent hover:underline mb-6">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>

      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4">
        {title}
      </h1>

      <div class="flex items-center gap-4 text-gray-500">
        <time datetime={date.toISOString()}>
          {formattedDate}
        </time>

        {tags.length > 0 && (
          <div class="flex gap-2">
            {tags.map((tag) => (
              <span class="text-sm px-2 py-1 bg-gray-100 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="max-w-3xl mx-auto prose prose-lg prose-gray">
      <slot />
    </div>
  </article>
</BaseLayout>