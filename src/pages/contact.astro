---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact" description="Get in touch - I'd love to hear from you">
  <section class="container py-12">
    <div class="max-w-2xl mx-auto">
      <header class="mb-12 text-center">
        <h1 class="text-4xl font-bold text-primary mb-4">Get in Touch</h1>
        <p class="text-lg text-secondary">
          Have a question or want to work together? Send me a message!
        </p>
      </header>

      <div class="bg-white rounded-xl shadow-sm p-8">
        <ContactForm />
      </div>

      <div class="mt-12 text-center">
        <p class="text-secondary mb-4">Or reach out directly:</p>
        <div class="flex justify-center gap-6">
          <a href="mailto:hello@example.com" class="text-accent hover:underline">
            hello@example.com
          </a>
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">
            GitHub
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">
            Twitter
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>